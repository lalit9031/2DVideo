{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/episode.schema.json",
  "title": "Episode",
  "type": "object",
  "required": ["episode_id", "type", "target_duration_sec", "title", "characters_used", "shots"],
  "properties": {
    "episode_id": { "type": "string" },
    "type": { "type": "string", "enum": ["poem", "story"] },
    "target_duration_sec": { "type": "integer", "minimum": 1 },
    "title": { "type": "string" },
    "characters_used": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "shots": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/shot" }
    },
    "generated_from_template": { "type": "string" },
    "created": { "type": "string" },
    "format": { "type": "string", "enum": ["short", "full"] },
    "scene_manifest": { "type": "array" },
    "animated_manifest": { "type": "array" },
    "upscale_manifest": { "type": "array" },
    "tts_manifest": { "type": "array" },
    "render_manifest": { "type": "array" },
    "broll_manifest": { "type": "array" }
  },
  "$defs": {
    "dialogueLine": {
      "type": "object",
      "required": ["character", "line", "voice_id"],
      "properties": {
        "character": { "type": "string" },
        "line": { "type": "string" },
        "voice_id": { "type": "string" },
        "audio_path": { "type": "string" },
        "tts_path": { "type": "string" },
        "timings": { "type": "array" }
      },
      "additionalProperties": false
    },
    "shot": {
      "type": "object",
      "required": ["shot_id", "duration_sec"],
      "properties": {
        "shot_id": { "type": "string" },
        "characters": {
          "type": "array",
          "items": { "type": "string" }
        },
        "action": { "type": "string" },
        "dialogue": {
          "type": "array",
          "items": { "$ref": "#/$defs/dialogueLine" }
        },
        "background": { "type": "string" },
        "duration_sec": { "type": "integer", "minimum": 1 },
        "broll": { "type": "boolean" },
        "video_prompt": { "type": "string" },
        "rendered_video": { "type": "string" },
        "image_prompt": { "type": "string" },
        "negative_prompt": { "type": "string" },
        "scene_image": { "type": "string" },
        "scene_image_upscaled": { "type": "string" },
        "animated_clip": { "type": "string" },
        "broll_render_mode": { "type": "string" },
        "tts_audio": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
